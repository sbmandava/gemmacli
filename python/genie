#!/usr/bin/env bash
set -euo pipefail

# Resolve the real location of this script, following symlinks. This lets the
# script be invoked via a symlink (e.g. /usr/local/bin/genie -> the real script)
# while still finding its Python helper next to it.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

# RAG settings: for large files, retrieve only the relevant chunks via LanceDB
# instead of stuffing the whole document into the (4096-token) context window.
RAG_DB="${GENIE_CACHE_DB:-$HOME/.genie/genie-cache.db}"
RAG_HELPER="$SCRIPT_DIR/genie_rag.py"
# Fallbacks if invoked as a bare copy rather than alongside its helper.
for cand in "$HOME/.local/share/genie/genie_rag.py" "$HOME/.genie/genie_rag.py"; do
    [[ -f "$RAG_HELPER" ]] && break
    RAG_HELPER="$cand"
done
GRAPH_HELPER="$SCRIPT_DIR/genie_graph.py"
for cand in "$HOME/.local/share/genie/genie_graph.py" "$HOME/.genie/genie_graph.py"; do
    [[ -f "$GRAPH_HELPER" ]] && break
    GRAPH_HELPER="$cand"
done
GRAPH_DB="${GENIE_GRAPH_DB:-$HOME/.genie/genie-graph.lbug}"
GRAPH_LOG="${GENIE_GRAPH_LOG:-$HOME/.genie/graph-update.log}"
BACKEND_CACHE="${GENIE_BACKEND_CACHE:-$HOME/.genie/backend}"
MODEL_DEFAULT_FILE="${GENIE_MODEL_DEFAULT_FILE:-$HOME/.genie/model_default}"
RAW_BASE="${GENIE_RAW_BASE:-https://raw.githubusercontent.com/sbmandava/gemma-genie/main}"
# Repo subdir holding the scripts (now python/). Self-update tries here first,
# then the legacy repo root. Override with GENIE_RAW_SUBDIR= (empty for root).
RAW_SUBDIR="${GENIE_RAW_SUBDIR-python}"
UPDATE_STAMP="${GENIE_UPDATE_STAMP:-$HOME/.genie/last_update_check}"
RAG_THRESHOLD_CHARS="${GENIE_RAG_THRESHOLD:-14000}"   # ~3500 tokens
RAG_TOPK="${GENIE_RAG_TOPK:-15}"
RAG_TTL="${GENIE_CACHE_TTL:-86400}"   # evict cached tables idle >24h
CHUNK_SIZE="${GENIE_CHUNK_SIZE:-}"    # chars per chunk (empty = helper default)
# Pin the litert-lm runtime so uvx resolves a known-good version instead of
# silently pulling a newer (possibly breaking) release on a cache miss.
LITERT_VERSION="0.13.1"
VERSION="0.2.4"

# All models (Gemma weights + the model2vec embedder) live in the HuggingFace
# hub cache: ${HF_HOME:-$HOME/.cache/huggingface}/hub
export HF_HOME="${HF_HOME:-$HOME/.cache/huggingface}"

usage() {
    cat <<EOF
Usage: $(basename "$0") [--model e2b|e4b] [--txt PATH | --doc PATH | --dir PATH] (--ask "QUESTION" | --image PATH | --audio PATH)

Options:
  --model e2b|e4b    Select model variant (default set at install by RAM:
                     <6GB -> e2b, >=6GB -> e4b; override here or via GENIE_MODEL)
  --ask "QUESTION"   Run text prompt (combine with --txt/--doc/--dir to analyze files)
  --txt PATH         Attach a text/CSV file's contents to the --ask prompt
  --doc PATH         Extract a document's text (PDF/DOCX/XLSX/PPTX/image via
                     liteparse) into the --ask prompt
  --dir PATH         Ingest all supported files in a directory (recursively) into
                     the LanceDB cache and answer from the most relevant chunks
  --pages RANGE      Limit --doc extraction to these pages, e.g. "1-5,10,15-20"
  --image PATH       Describe the given image using vision backend
  --audio PATH       Transcribe the given audio file using audio backend
  --top-k N          Chunks retrieved per query (default: 15)
  --chunk-size N     Characters per chunk when embedding (default: 1000)
  -h, --help         Show this help and exit
  -V, --version      Print version and exit

Subcommands / inspection:
  doctor                    Run the dependency check and exit
  cache [info|list|clear]   Inspect or clear the LanceDB vector cache
  --graph-stats             Show correlation-graph stats + top hubs
  --graph-query "<cypher>"  Run a raw Cypher query against the graph
  --uninstall [-y]          Remove models, caches, symlinks, and scripts
  --verify-models           Checksum (sha256) the downloaded model weights

Analyzing files with --txt/--doc/--dir also auto-updates a LadybugDB
correlation graph (entities per file; --dir uses Gemma for extraction). A bare
--ask automatically consults whatever you've indexed in the last 24h (LanceDB
chunks + graph correlations). Both caches live under ~/.genie and expire after 24h.

Piped input: when no --txt/--doc/--dir is given, stdin is read as the document,
  e.g.  cat notes.txt | $(basename "$0") --ask "summarize this"
EOF
}

help_extra() {
    cat <<EOF

Large files (>${RAG_THRESHOLD_CHARS} chars) are automatically chunked, embedded
(model2vec) and stored in a LanceDB cache at:
  ${RAG_DB}
Only the chunks most relevant to your question are sent to the model.
Cached tables idle for >24h are evicted automatically on the next run.

Models (Gemma weights + embedder) are stored in the HuggingFace hub cache:
  ${HF_HOME}/hub
Env overrides: GENIE_CACHE_DB, GENIE_RAG_THRESHOLD, GENIE_RAG_TOPK, GENIE_CACHE_TTL, HF_HOME
EOF
}

check_deps() {
    local issues=0
    echo
    echo "Dependency check:"

    if command -v uvx >/dev/null 2>&1; then
        printf '  %-9s %s\n' "[ok]" "uvx (uv) — runs the model, liteparse, and RAG"
    else
        printf '  %-9s %s\n' "[MISSING]" "uvx (uv) — REQUIRED. Install: https://docs.astral.sh/uv/"
        issues=$((issues + 1))
    fi

    if [[ -f "$RAG_HELPER" ]]; then
        printf '  %-9s %s\n' "[ok]" "RAG helper ($RAG_HELPER)"
    else
        printf '  %-9s %s\n' "[MISSING]" "RAG helper not found at $RAG_HELPER — large-file retrieval disabled"
        issues=$((issues + 1))
    fi

    if command -v soffice >/dev/null 2>&1; then
        printf '  %-9s %s\n' "[ok]" "LibreOffice (soffice) — enables DOCX/XLSX/PPTX via --doc"
    else
        printf '  %-9s %s\n' "[warn]" "LibreOffice (soffice) not found — DOCX/XLSX/PPTX need it (PDF/images are fine)"
        printf '  %-9s %s\n' "" "install: $(libreoffice_install_cmd)"
    fi

    printf '  %-9s %s\n' "[note]" "liteparse, litert-lm, lancedb, model2vec, ladybug auto-install via uvx on first use"

    # Report the backend genie will actually use right now, and — crucially —
    # don't just trust a cached "gpu": actually run a tiny generation on the GPU
    # with litert-lm to confirm it works, falling back to CPU (and correcting the
    # cache) if it doesn't. Needs the model downloaded and uvx available to probe.
    local raw src forced=0
    if [[ -n "${GENIE_BACKEND:-}" ]]; then
        raw="$GENIE_BACKEND"; src="forced via GENIE_BACKEND"; forced=1
    elif [[ -s "$BACKEND_CACHE" ]]; then
        raw="$(cat "$BACKEND_CACHE")"; src="cached"
    else
        raw=""; src=""
    fi

    setup_litert_run
    local can_probe=0
    [[ -n "$MODEL_PATH" ]] && command -v uvx >/dev/null 2>&1 && can_probe=1

    if [[ -z "$raw" ]]; then
        # Never decided before — detect now if we can, otherwise defer.
        if [[ $can_probe -eq 1 ]]; then ensure_uvx; raw="$(resolve_backend)"; src="auto-detected just now"
        else raw="unknown"; src="will auto-detect on first query"; fi
    elif [[ "$raw" == "gpu" && $can_probe -eq 1 ]]; then
        # Verify the cached/forced GPU choice really runs.
        ensure_uvx
        if verify_gpu; then
            src="$src, verified working with litert-lm"
        elif [[ $forced -eq 1 ]]; then
            src="forced via GENIE_BACKEND — WARNING: GPU did not run with litert-lm"
        else
            raw="cpu"; src="GPU did not run with litert-lm — fell back to CPU"
            printf '%s' cpu > "$BACKEND_CACHE" 2>/dev/null || true
        fi
    elif [[ "$raw" == "gpu" ]]; then
        src="$src (model not downloaded yet — not verified)"
    fi
    local be; be="$(printf '%s' "$raw" | tr '[:lower:]' '[:upper:]')"
    printf '  %-9s %s\n' "[info]" "compute backend: $be ($src)"
    printf '  %-9s %s\n' "[info]" "default model: $(resolve_default_model) (system RAM: $(detect_total_gb)GB; override with --model / GENIE_MODEL)"

    echo
    if [[ $issues -eq 0 ]]; then
        echo "All required dependencies present."
    else
        echo "Issues: $issues required dependency(ies) missing (see above)."
    fi
}

version_gt() {  # true if $1 is a strictly higher version than $2
    [[ "$1" != "$2" ]] && [[ "$(printf '%s\n%s\n' "$1" "$2" | sort -V 2>/dev/null | tail -1)" == "$1" ]]
}

# Check the repo for a newer version at most once per 24h; if found, atomically
# swap in the new files (effective next run). Best-effort, non-blocking, and
# skipped for git checkouts (don't clobber a dev tree) and when GENIE_NO_UPDATE=1.
maybe_self_update() {
    [[ "${GENIE_NO_UPDATE:-0}" == "1" ]] && return 0
    [[ -d "$SCRIPT_DIR/.git" ]] && return 0
    command -v curl >/dev/null 2>&1 || return 0
    if [[ -f "$UPDATE_STAMP" ]]; then
        local last now; last=$(cat "$UPDATE_STAMP" 2>/dev/null || echo 0); now=$(date +%s)
        [[ $(( now - last )) -lt 86400 ]] && return 0
    fi
    mkdir -p "$(dirname "$UPDATE_STAMP")"; date +%s > "$UPDATE_STAMP"
    local remote_ver
    remote_ver=$(raw_fetch genie 2>/dev/null | grep -m1 '^VERSION=' | cut -d'"' -f2)
    [[ -n "$remote_ver" ]] || return 0
    if version_gt "$remote_ver" "$VERSION"; then
        echo "genie: upgrading $VERSION -> $remote_ver..." >&2
        local f ok=1
        for f in genie genie_rag.py genie_graph.py install.sh; do
            raw_fetch "$f" > "$SCRIPT_DIR/.$f.new" 2>/dev/null \
                && [[ -s "$SCRIPT_DIR/.$f.new" ]] \
                && mv "$SCRIPT_DIR/.$f.new" "$SCRIPT_DIR/$f" || { ok=0; rm -f "$SCRIPT_DIR/.$f.new"; }
        done
        chmod +x "$SCRIPT_DIR/genie" 2>/dev/null
        [[ $ok -eq 1 ]] && echo "genie: upgraded to $remote_ver (effective next run)." >&2
    fi
}

# Fetch a repo file to stdout, trying the python/ layout first, then repo root,
# so self-update works whether or not the repo has been restructured.
raw_fetch() {  # raw_fetch <filename>
    curl -fsSL "$RAW_BASE/$RAW_SUBDIR/$1" 2>/dev/null \
        || curl -fsSL "$RAW_BASE/$1" 2>/dev/null
}

detect_total_gb() {  # total system RAM in whole GB
    local bytes=0
    if [[ "$(uname)" == "Darwin" ]]; then
        bytes=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
    elif [[ -r /proc/meminfo ]]; then
        bytes=$(( $(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0) * 1024 ))
    fi
    echo $(( bytes / 1024 / 1024 / 1024 ))
}

# Print the OS-appropriate command to install a *minimal* LibreOffice — just the
# headless components liteparse needs to convert DOCX/XLSX/PPTX, not the full GUI
# suite. Used by the dependency check and the --doc guard.
libreoffice_install_cmd() {
    case "$(uname)" in
        Darwin) printf 'brew install --cask libreoffice' ;;
        Linux)
            if   command -v apt-get >/dev/null 2>&1; then
                printf 'sudo apt-get update && sudo apt-get install -y --no-install-recommends libreoffice-core libreoffice-writer libreoffice-calc libreoffice-impress'
            elif command -v dnf >/dev/null 2>&1; then
                printf 'sudo dnf install -y libreoffice-core libreoffice-writer libreoffice-calc libreoffice-impress'
            elif command -v yum >/dev/null 2>&1; then
                printf 'sudo yum install -y libreoffice-core libreoffice-writer libreoffice-calc libreoffice-impress'
            elif command -v pacman >/dev/null 2>&1; then
                printf 'sudo pacman -S --noconfirm libreoffice-still'
            elif command -v zypper >/dev/null 2>&1; then
                printf 'sudo zypper install -y libreoffice'
            else
                printf 'install LibreOffice (it provides the `soffice` command)'
            fi ;;
        *) printf 'install LibreOffice (it provides the `soffice` command)' ;;
    esac
}

verify_one_model() {  # repo, filename — compare on-disk sha256 to the HF LFS blob hash
    local repo="$1" file="$2"
    local snaps="$HF_HOME/hub/models--${repo//\//--}/snapshots"
    local f; f="$(find "$snaps" -name "$file" 2>/dev/null | head -1)"
    [[ -n "$f" ]] || { printf '  %-10s %s\n' "MISSING" "$repo"; return 1; }
    # HF stores LFS blobs named by their sha256; the snapshot file links to it.
    local expected; expected="$(basename "$(readlink "$f" 2>/dev/null || echo "$f")")"
    if [[ ! "$expected" =~ ^[0-9a-f]{64}$ ]]; then
        printf '  %-10s %s\n' "PRESENT" "$repo (no LFS hash to check)"; return 0
    fi
    local actual; actual="$(shasum -a 256 "$f" 2>/dev/null | cut -d' ' -f1)"
    if [[ "$actual" == "$expected" ]]; then
        printf '  %-10s %s\n' "OK" "$repo"
    else
        printf '  %-10s %s\n' "CORRUPT" "$repo (sha256 mismatch — re-run install to repair)"; return 1
    fi
}

cmd_verify_models() {
    echo "Verifying model weights (sha256) in $HF_HOME/hub ..."
    local rc=0
    verify_one_model "litert-community/gemma-4-E2B-it-litert-lm" "gemma-4-E2B-it.litertlm" || rc=1
    verify_one_model "litert-community/gemma-4-E4B-it-litert-lm" "gemma-4-E4B-it.litertlm" || rc=1
    if [[ $rc -eq 0 ]]; then echo "All present models verified."; else
        echo "Some models are missing or corrupt — re-run the installer to repair."; fi
    return $rc
}

cmd_uninstall() {
    local yes=0
    [[ "${1:-}" == "-y" || "${1:-}" == "--yes" ]] && yes=1
    echo "Gemma Genie uninstall will remove:"
    echo "  - data & settings:   $HOME/.genie"
    echo "  - model weights:     $HF_HOME/hub (Gemma + embedder)"
    echo "  - command symlinks:  /usr/local/bin/genie, $HOME/.local/bin/genie"
    echo "  - installed scripts: $SCRIPT_DIR (skipped if it's a git checkout)"
    echo "  (uv and LibreOffice are left installed.)"
    if [[ $yes -ne 1 ]]; then
        printf "Proceed? [y/N] "
        read -r ans || ans=""
        [[ "$ans" =~ ^[Yy] ]] || { echo "Aborted."; return 1; }
    fi
    rm -rf "$HOME/.genie" && echo "Removed $HOME/.genie"
    rm -rf "$HF_HOME"/hub/models--litert-community--gemma-4-* 2>/dev/null && echo "Removed Gemma model weights"
    rm -rf "$HF_HOME"/hub/models--minishlab--potion-retrieval-32M 2>/dev/null && echo "Removed embedder weights"
    local b
    for b in /usr/local/bin/genie "$HOME/.local/bin/genie"; do
        if [[ -L "$b" || -e "$b" ]]; then
            rm -f "$b" 2>/dev/null || sudo rm -f "$b" 2>/dev/null
            echo "Removed $b"
        fi
    done
    if [[ -d "$SCRIPT_DIR/.git" ]]; then
        echo "Note: $SCRIPT_DIR is a git checkout — left intact (remove manually if desired)."
    else
        rm -f "$SCRIPT_DIR"/genie "$SCRIPT_DIR"/genie_rag.py "$SCRIPT_DIR"/genie_graph.py \
              "$SCRIPT_DIR"/install.sh "$SCRIPT_DIR"/genie.png 2>/dev/null
        rmdir "$SCRIPT_DIR" 2>/dev/null
        echo "Removed installed scripts in $SCRIPT_DIR"
    fi
    echo "Gemma Genie uninstalled."
}

# Default model: GENIE_MODEL env > cached choice (set at install from RAM) >
# runtime RAM check (>=6GB -> e4b, else e2b).
resolve_default_model() {
    if [[ -n "${GENIE_MODEL:-}" ]]; then printf '%s' "$GENIE_MODEL"; return; fi
    if [[ -s "$MODEL_DEFAULT_FILE" ]]; then cat "$MODEL_DEFAULT_FILE"; return; fi
    [[ "$(detect_total_gb)" -ge 6 ]] && printf 'e4b' || printf 'e2b'
}

ensure_uvx() {
    command -v uvx >/dev/null 2>&1 && return 0
    echo "uv (uvx) not found — installing via https://astral.sh/uv ..." >&2
    curl -LsSf https://astral.sh/uv/install.sh | sh >&2 || {
        echo "Error: failed to install uv. See https://docs.astral.sh/uv/" >&2
        exit 1
    }
    export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
    command -v uvx >/dev/null 2>&1 || {
        echo "Error: uv installed but uvx not on PATH. Open a new shell and retry." >&2
        exit 1
    }
    echo "uv installed." >&2
}

cmd_cache() {
    local sub="${1:-info}"
    case "$sub" in
        ""|info|status)
            echo "Vector cache: $RAG_DB"
            if [[ -d "$RAG_DB" ]]; then
                local n
                n=$(find "$RAG_DB" -maxdepth 1 -name "*.lance" 2>/dev/null | wc -l | tr -d ' ')
                echo "Size:           $(du -sh "$RAG_DB" 2>/dev/null | cut -f1)"
                echo "Indexed tables: $n"
                echo "Eviction TTL:   ${RAG_TTL}s"
            else
                echo "(empty — nothing indexed yet)"
            fi
            ;;
        list)
            if [[ -d "$RAG_DB" ]]; then
                find "$RAG_DB" -maxdepth 1 -name "*.lance" 2>/dev/null \
                    | sed -E 's#.*/##; s#\.lance$##' | sort
            else
                echo "(empty)"
            fi
            ;;
        clear)
            rm -rf "$RAG_DB"
            echo "Cleared vector cache: $RAG_DB"
            ;;
        *)
            echo "Usage: $(basename "$0") cache [info|list|clear]" >&2
            return 1
            ;;
    esac
}

graph_model_path() {  # echo cached E4B model path (for --llm extraction), if present
    local repo="litert-community/gemma-4-E4B-it-litert-lm" file="gemma-4-E4B-it.litertlm"
    find "$HF_HOME/hub/models--${repo//\//--}/snapshots" -name "$file" 2>/dev/null | head -1
}

# Invoke the graph helper (update/stats/query). Best-effort for updates.
run_graph() {
    ensure_uvx
    uvx --python 3.12 --with ladybug==0.17.1 python "$GRAPH_HELPER" \
        --db "$GRAPH_DB" --ttl "$RAG_TTL" "$@"
}

abspath_of() {  # absolute path of a (possibly relative) file path
    local p="$1"
    [[ "$p" == /* ]] && { printf '%s' "$p"; return; }
    printf '%s' "$(cd "$(dirname "$p")" 2>/dev/null && pwd)/$(basename "$p")"
}

# Print a "Sources:" footer listing unique source paths found in retrieved
# context (lines marked "[source: <path>]").
print_sources() {
    local ctx="$1" srcs
    # The grep returns non-zero when there are no [source: ...] markers (e.g. a
    # plain question with no indexed files). Under `set -euo pipefail` that would
    # otherwise abort the whole script right after the answer was printed, so the
    # `|| true` keeps an empty result from being treated as a failure.
    srcs=$(printf '%s\n' "$ctx" | grep -oE '\[source: [^]]+\]' \
        | sed -E 's/^\[source: (.*)\]$/\1/' | awk '!seen[$0]++') || true
    if [[ -n "$srcs" ]]; then
        printf '\nSources:\n'
        while IFS= read -r s; do [[ -n "$s" ]] && printf '  - %s\n' "$s"; done <<< "$srcs"
    fi
}

# Known-harmless chatter the GPU/OpenCL backend emits. These come from the prebuilt
# litert-lm runtime's underlying GPU delegate (not from genie or LiteRT-LM itself,
# which already raises its log level to ERROR) and only clutter the output. The
# "Warning: maxDynamic..." lines go to stderr; the "Loaded OpenCL library" line is
# printed to stdout at init, before any answer tokens — so we filter both streams.
LITERT_NOISE_RE='maxDynamicUniformBuffersPerPipelineLayout|maxDynamicStorageBuffersPerPipelineLayout|Loaded OpenCL library with dlopen'

# litert-lm prints this to stdout when a generation fails (it can still exit 0),
# so it's a more reliable failure signal than the exit code alone.
LITERT_ERROR_RE='^[[:space:]]*An error occurred'

# One model invocation. Filters the GPU noise from both streams and streams the
# answer live (grep --line-buffered; tee stays line-buffered to a TTY, so live
# streaming is preserved). The answer is ALSO copied to the capture file named by
# $1 so the caller can tell whether a real answer was produced — the function's
# stdout remains the live answer (do not call this in $() or streaming is lost).
# `set +e` keeps a non-zero / teardown exit from aborting under `set -e`.
_run_llm_once() {
    local cap="$1"; shift
    set +e
    "${LITERT_RUN[@]}" "$@" \
        2> >(grep -vE "$LITERT_NOISE_RE" >&2) \
        | grep --line-buffered -vE "$LITERT_NOISE_RE" \
        | tee "$cap"
    set -e
}

# Emit the argument list with the GPU backend swapped for CPU, NUL-delimited
# (handles both "--backend=gpu" and the two-token "--vision-backend gpu" form).
_args_gpu_to_cpu() {
    local a
    for a in "$@"; do
        case "$a" in
            --backend=gpu)        printf '%s\0' "--backend=cpu" ;;
            --vision-backend=gpu) printf '%s\0' "--vision-backend=cpu" ;;
            gpu)                  printf '%s\0' "cpu" ;;
            *)                    printf '%s\0' "$a" ;;
        esac
    done
}

# Run the on-device model with automatic CPU fallback: if a GPU run produces no
# real answer (no output, or litert's "An error occurred"), retry once on CPU so
# the user still gets an answer. A successful GPU run is never re-run, so there's
# no double output. The fallback is remembered for the rest of this process (and
# cached for future runs, unless the backend was explicitly forced) so we don't
# keep hammering a broken GPU; `genie doctor` re-verifies and can restore GPU.
run_llm() {
    local cap body
    cap="$(mktemp)"
    _run_llm_once "$cap" "$@"
    # A real answer is captured output that isn't just litert's error marker.
    body="$(grep -vE "$LITERT_ERROR_RE" "$cap" 2>/dev/null | tr -d '[:space:]' || true)"
    rm -f "$cap"

    if [[ -z "$body" && "$BACKEND" == "gpu" ]]; then
        echo "genie: GPU backend produced no answer — retrying on CPU..." >&2
        local -a cpu_args=()
        while IFS= read -r -d '' a; do cpu_args+=("$a"); done < <(_args_gpu_to_cpu "$@")
        BACKEND=cpu
        [[ -z "${GENIE_BACKEND:-}" ]] && { printf '%s' cpu > "$BACKEND_CACHE" 2>/dev/null || true; }
        cap="$(mktemp)"
        _run_llm_once "$cap" "${cpu_args[@]}"
        rm -f "$cap"
    fi
    return 0
}

# Actually run a tiny generation on the GPU with litert-lm. Returns 0 only if the
# GPU backend genuinely works end-to-end, non-zero otherwise (no GPU, driver/
# OpenCL issue, etc.). Requires LITERT_RUN to be set (call setup_litert_run first).
#
# Notes:
#  - --max-num-tokens budgets input+output, so it must comfortably exceed the
#    prompt length; too small (e.g. 8) makes litert reject the prompt as "too
#    long" — not a GPU failure. 64 matches the install-time probe.
#  - The CLI can exit 0 even when generation failed (it prints "An error
#    occurred"), so we check the output too rather than trusting the exit code.
verify_gpu() {
    local out
    out="$("${LITERT_RUN[@]}" --backend=gpu --max-num-tokens 64 --prompt "ok" 2>/dev/null)" || return 1
    [[ -n "$out" && "$out" != *"An error occurred"* ]]
}

# Pick the compute backend: honor GENIE_BACKEND, else use the cached choice,
# else probe the GPU once (fall back to CPU if it fails) and cache the result.
resolve_backend() {
    if [[ -n "${GENIE_BACKEND:-}" ]]; then printf '%s' "$GENIE_BACKEND"; return; fi
    if [[ -s "$BACKEND_CACHE" ]]; then cat "$BACKEND_CACHE"; return; fi
    local b="cpu"
    echo "Detecting compute backend (one-time)..." >&2
    if verify_gpu; then b="gpu"; fi
    mkdir -p "$(dirname "$BACKEND_CACHE")"
    printf '%s' "$b" > "$BACKEND_CACHE"
    echo "Using $b backend (cached in $BACKEND_CACHE)." >&2
    printf '%s' "$b"
}

# Resolve the model file in the HF cache and build the LITERT_RUN command into
# globals (HF_REPO, MODEL_FILE, MODEL_PATH, LITERT_RUN). MODEL_PATH is empty when
# the weights aren't downloaded yet. Safe to call before BACKEND is known.
setup_litert_run() {
    case "$model_variant" in
        e2b) HF_REPO="litert-community/gemma-4-E2B-it-litert-lm"; MODEL_FILE="gemma-4-E2B-it.litertlm" ;;
        e4b) HF_REPO="litert-community/gemma-4-E4B-it-litert-lm"; MODEL_FILE="gemma-4-E4B-it.litertlm" ;;
    esac
    MODEL_SNAPS="$HF_HOME/hub/models--${HF_REPO//\//--}/snapshots"
    # `find` exits non-zero when the snapshots dir doesn't exist yet (model not
    # downloaded); the `|| true` keeps that from tripping `set -e` (MODEL_PATH
    # is then empty, which the caller handles).
    MODEL_PATH="$(find "$MODEL_SNAPS" -name "$MODEL_FILE" 2>/dev/null | head -1 || true)"
    if [[ -n "$MODEL_PATH" && -e "$MODEL_PATH" ]]; then
        LITERT_RUN=(uvx "litert-lm@${LITERT_VERSION}" run "$MODEL_PATH")
    else
        LITERT_RUN=(uvx "litert-lm@${LITERT_VERSION}" run --from-huggingface-repo "$HF_REPO" "$MODEL_FILE")
    fi
}

model_variant="$(resolve_default_model)"   # RAM-based default; override with --model
model_explicit=false
action=""
arg=""
txt_path=""
doc_path=""
dir_path=""
pages=""

# Background, rate-limited self-update check (atomic; effective next run).
( maybe_self_update & ) 2>/dev/null

# Subcommands / standalone flags (must be the first argument).
case "${1:-}" in
    -V|--version|version) echo "Gemma Genie $VERSION"; exit 0 ;;
    doctor)               echo "Gemma Genie $VERSION"; check_deps; exit 0 ;;
    cache)                shift; cmd_cache "$@"; exit $? ;;
    --uninstall|uninstall) shift; cmd_uninstall "$@"; exit $? ;;
    --verify-models)       cmd_verify_models; exit $? ;;
    --graph-stats)        mkdir -p "$(dirname "$GRAPH_DB")"; run_graph --mode stats; exit $? ;;
    --graph-query)
        [[ -n "${2:-}" ]] || { echo "Usage: $(basename "$0") --graph-query \"<cypher>\"" >&2; exit 1; }
        run_graph --mode query --cypher "$2"; exit $?
        ;;
esac

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)
            [[ $# -ge 2 ]] || { echo "Error: --model requires a value" >&2; usage; exit 1; }
            case "$2" in
                e2b|e4b) model_variant="$2"; model_explicit=true ;;
                *) echo "Error: --model must be e2b or e4b" >&2; exit 1 ;;
            esac
            shift 2
            ;;
        --txt)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --txt requires a value" >&2; usage; exit 1; }
            [[ -f "$2" ]] || { echo "Error: text file not found: $2" >&2; exit 1; }
            txt_path="$2"
            shift 2
            ;;
        --doc)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --doc requires a value" >&2; usage; exit 1; }
            [[ -f "$2" ]] || { echo "Error: document not found: $2" >&2; exit 1; }
            doc_path="$2"
            shift 2
            ;;
        --dir)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --dir requires a value" >&2; usage; exit 1; }
            [[ -d "$2" ]] || { echo "Error: directory not found: $2" >&2; exit 1; }
            dir_path="$2"
            shift 2
            ;;
        --pages)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --pages requires a value" >&2; usage; exit 1; }
            pages="$2"
            shift 2
            ;;
        --top-k)
            [[ $# -ge 2 && "${2:-}" =~ ^[0-9]+$ ]] || { echo "Error: --top-k requires a number" >&2; exit 1; }
            RAG_TOPK="$2"
            shift 2
            ;;
        --chunk-size)
            [[ $# -ge 2 && "${2:-}" =~ ^[0-9]+$ ]] || { echo "Error: --chunk-size requires a number" >&2; exit 1; }
            CHUNK_SIZE="$2"
            shift 2
            ;;
        -V|--version)
            echo "Gemma Genie $VERSION"; exit 0
            ;;
        --ask|--image|--audio)
            [[ -z "$action" ]] || { echo "Error: only one of --ask/--image/--audio allowed" >&2; exit 1; }
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: $1 requires a value" >&2; usage; exit 1; }
            action="$1"
            arg="$2"
            shift 2
            ;;
        -h|--help)
            usage
            help_extra
            check_deps
            exit 0
            ;;
        *)
            echo "Error: unknown argument: $1" >&2
            usage
            exit 1
            ;;
    esac
done

if [[ -z "$action" ]]; then
    usage
    exit 1
fi

inputs=0
[[ -n "$txt_path" ]] && inputs=$((inputs + 1))
[[ -n "$doc_path" ]] && inputs=$((inputs + 1))
[[ -n "$dir_path" ]] && inputs=$((inputs + 1))
if [[ $inputs -gt 1 ]]; then
    echo "Error: use only one of --txt, --doc or --dir" >&2
    exit 1
fi

if [[ $inputs -eq 1 && "$action" != "--ask" ]]; then
    echo "Error: --txt/--doc/--dir can only be used with --ask" >&2
    exit 1
fi

if [[ -n "$pages" && -z "$doc_path" ]]; then
    echo "Error: --pages requires --doc" >&2
    exit 1
fi

# Piped input: with --ask and no file/dir, read the document from stdin.
from_stdin=0
STDIN_TEXT=""
if [[ "$action" == "--ask" && $inputs -eq 0 && ! -t 0 ]]; then
    STDIN_TEXT="$(cat)"
    [[ -n "$STDIN_TEXT" ]] && from_stdin=1
fi

# Models live in the HuggingFace hub cache (~/.cache/huggingface/hub). If the
# file is already cached we run it directly from that path — no network check,
# no "Downloading..." message. Only the first run (cache miss) pulls from HF.
setup_litert_run

ensure_uvx  # install uv on demand if it's missing
BACKEND="$(resolve_backend)"  # gpu, or cpu if the GPU backend isn't available

case "$action" in
    --ask)
        prompt="$arg"
        rag_extra=()
        [[ -n "$CHUNK_SIZE" ]] && rag_extra+=(--chunk-size "$CHUNK_SIZE")

        if [[ -n "$dir_path" ]]; then
            # Directory knowledge base: ingest (incrementally) and retrieve.
            mkdir -p "$(dirname "$RAG_DB")"
            echo "Indexing \"$dir_path\" into LanceDB (incremental)..." >&2
            context="$(uvx --python 3.12 --with lancedb==0.33.0 --with model2vec==0.8.2 \
                python "$RAG_HELPER" \
                --db "$RAG_DB" \
                --dir "$dir_path" \
                --recursive \
                --query "$arg" \
                --top-k "$RAG_TOPK" \
                --ttl "$RAG_TTL" \
                ${rag_extra[@]+"${rag_extra[@]}"})"
            prompt="$arg

Use the following excerpts from files in \"$dir_path\" to answer
(each excerpt is labeled with its source file):

$context"
            run_llm --backend="$BACKEND" --prompt="$prompt"
            print_sources "$context"
            # Auto-update the correlation graph in the BACKGROUND (LLM extraction
            # for directories is slow on first build; detach so the answer is
            # not blocked). Progress is logged to GRAPH_LOG.
            mkdir -p "$(dirname "$GRAPH_DB")"
            graph_args=(--mode update --dir "$dir_path" --recursive)
            mp="$(graph_model_path)"; [[ -n "$mp" ]] && graph_args+=(--llm --model "$mp" --backend "$BACKEND")
            echo "Updating correlation graph in background (log: $GRAPH_LOG)" >&2
            ( run_graph "${graph_args[@]}" >>"$GRAPH_LOG" 2>&1 & )
            exit 0
        fi

        src=""
        extracted=""
        if [[ -n "$txt_path" ]]; then
            src="$txt_path"
            extracted="$(cat "$txt_path")"
        elif [[ -n "$doc_path" ]]; then
            src="$doc_path"
            # Office formats (DOCX/XLSX/PPTX and legacy/ODF variants) require
            # LibreOffice's `soffice` for liteparse to convert them; PDFs and
            # images do not. Fail early with an actionable, OS-aware install
            # command instead of a cryptic liteparse error deeper down.
            doc_ext="$(printf '%s' "${doc_path##*.}" | tr '[:upper:]' '[:lower:]')"
            case "$doc_ext" in
                docx|doc|xlsx|xls|pptx|ppt|odt|ods|odp)
                    if ! command -v soffice >/dev/null 2>&1; then
                        echo "Error: parsing '$doc_path' needs LibreOffice, but the 'soffice' command was not found." >&2
                        echo "Install the minimal LibreOffice components with:" >&2
                        echo "  $(libreoffice_install_cmd)" >&2
                        exit 1
                    fi ;;
            esac
            parse_args=(--quiet "$doc_path")
            [[ -n "$pages" ]] && parse_args+=(--target-pages "$pages")
            extracted="$(uvx --from liteparse==2.0.6 lit parse "${parse_args[@]}")"
        elif [[ $from_stdin -eq 1 ]]; then
            src="(stdin)"
            extracted="$STDIN_TEXT"
        fi

        src_footer=""   # context (or marker) used to print the Sources: footer
        if [[ -n "$src" ]]; then
            # Full source path that gets stored and shown.
            if [[ $from_stdin -eq 1 ]]; then src_disp="(stdin)"; else src_disp="$(abspath_of "$src")"; fi
            if [[ ${#extracted} -gt $RAG_THRESHOLD_CHARS ]]; then
                # Large input: retrieve only the relevant chunks via LanceDB.
                mkdir -p "$(dirname "$RAG_DB")"
                if [[ $from_stdin -eq 1 ]]; then
                    cache_key="stdin|$(printf '%s' "$extracted" | shasum | cut -d' ' -f1)|cs=${CHUNK_SIZE}"
                else
                    cache_key="$src|$(stat -f '%z-%m' "$src")|pages=${pages}|cs=${CHUNK_SIZE}"
                fi
                echo "Large input (${#extracted} chars) — retrieving relevant chunks via LanceDB..." >&2
                context="$(printf '%s' "$extracted" | uvx --python 3.12 --with lancedb==0.33.0 --with model2vec==0.8.2 \
                    python "$RAG_HELPER" \
                    --db "$RAG_DB" \
                    --cache-key "$cache_key" \
                    --source "$src_disp" \
                    --query "$arg" \
                    --top-k "$RAG_TOPK" \
                    --ttl "$RAG_TTL" \
                    ${rag_extra[@]+"${rag_extra[@]}"})"
                prompt="$arg

Use the following excerpts from \"$src_disp\" to answer:

$context"
                src_footer="$context"
            else
                prompt="$arg

Analyze the following document (\"$src_disp\"):

$extracted"
                src_footer="[source: $src_disp]"
            fi
        elif [[ $inputs -eq 0 && $from_stdin -eq 0 ]]; then
            # Bare --ask: automatically consult data ingested in the last 24h
            # (LanceDB chunks + LadybugDB entity correlations).
            kb_ctx=""
            if [[ -d "$RAG_DB" ]]; then
                kb_ctx="$(uvx --python 3.12 --with lancedb==0.33.0 --with model2vec==0.8.2 \
                    python "$RAG_HELPER" --db "$RAG_DB" --search-all \
                    --query "$arg" --top-k "$RAG_TOPK" --ttl "$RAG_TTL" 2>/dev/null || true)"
            fi
            graph_ctx=""
            if [[ -e "$GRAPH_DB" ]]; then
                graph_ctx="$(run_graph --mode correlate --query "$arg" 2>/dev/null || true)"
            fi
            if [[ -n "$kb_ctx" || -n "$graph_ctx" ]]; then
                prompt="$arg

Answer using the knowledge-graph relationships and document excerpts below
(retrieved from the user's indexed data). Ground every claim in this evidence,
pay attention to source file names, and use the graph relationships to
disambiguate how entities relate (e.g. owner/builder vs. customer/brand).
${graph_ctx:+
Knowledge-graph relationships:
$graph_ctx}
${kb_ctx:+
Document excerpts:
$kb_ctx}"
                src_footer="$kb_ctx"
            fi
        fi

        run_llm \
            --backend="$BACKEND" \
            --prompt="$prompt"
        print_sources "$src_footer"

        # Auto-update the correlation graph for single files (heuristic, fast),
        # in the background so the answer isn't blocked.
        if [[ -n "$txt_path" || -n "$doc_path" ]]; then
            mkdir -p "$(dirname "$GRAPH_DB")"
            g_sig="$(stat -f '%z-%m' "$src" 2>/dev/null || echo 0)"
            ( printf '%s' "$extracted" | run_graph --mode update \
                --file-name "$src" --sig "$g_sig" >>"$GRAPH_LOG" 2>&1 & )
        fi
        ;;
    --image)
        run_llm \
            --backend="$BACKEND" --vision-backend "$BACKEND" \
            --attachment "$arg" --prompt describe
        ;;
    --audio)
        run_llm \
            --backend="$BACKEND" --audio-backend cpu \
            --attachment "$arg" --prompt transcribe
        ;;
esac
