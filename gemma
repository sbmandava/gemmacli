#!/usr/bin/env bash
set -euo pipefail

# Resolve the real location of this script, following symlinks. This lets the
# script be invoked via a symlink (e.g. /usr/local/bin/gemma -> the real script)
# while still finding its Python helper next to it.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

# RAG settings: for large files, retrieve only the relevant chunks via LanceDB
# instead of stuffing the whole document into the (4096-token) context window.
RAG_DB="${GEMMA_CACHE_DB:-$HOME/.gemma/gemma-cache.db}"
RAG_HELPER="$SCRIPT_DIR/gemma_rag.py"
# Fallbacks if invoked as a bare copy rather than alongside its helper.
for cand in "/opt/projects/unovie/gemmacli/gemma_rag.py" "$HOME/.gemma/gemma_rag.py"; do
    [[ -f "$RAG_HELPER" ]] && break
    RAG_HELPER="$cand"
done
GRAPH_HELPER="$SCRIPT_DIR/gemma_graph.py"
for cand in "/opt/projects/unovie/gemmacli/gemma_graph.py" "$HOME/.gemma/gemma_graph.py"; do
    [[ -f "$GRAPH_HELPER" ]] && break
    GRAPH_HELPER="$cand"
done
GRAPH_DB="${GEMMA_GRAPH_DB:-$HOME/.gemma/gemma-graph.lbug}"
GRAPH_LOG="${GEMMA_GRAPH_LOG:-$HOME/.gemma/graph-update.log}"
BACKEND_CACHE="${GEMMA_BACKEND_CACHE:-$HOME/.gemma/backend}"
RAG_THRESHOLD_CHARS="${GEMMA_RAG_THRESHOLD:-14000}"   # ~3500 tokens
RAG_TOPK="${GEMMA_RAG_TOPK:-15}"
RAG_TTL="${GEMMA_CACHE_TTL:-86400}"   # evict cached tables idle >24h
CHUNK_SIZE="${GEMMA_CHUNK_SIZE:-}"    # chars per chunk (empty = helper default)
VERSION="0.2.0"

# All models (Gemma weights + the model2vec embedder) live in the HuggingFace
# hub cache: ${HF_HOME:-$HOME/.cache/huggingface}/hub
export HF_HOME="${HF_HOME:-$HOME/.cache/huggingface}"

usage() {
    cat <<EOF
Usage: $(basename "$0") [--model e2b|e4b] [--txt PATH | --doc PATH | --dir PATH] (--ask "QUESTION" | --image PATH | --audio PATH)

Options:
  --model e2b|e4b    Select model variant (default: e2b; e4b when --txt/--doc/--dir is used)
  --ask "QUESTION"   Run text prompt (combine with --txt/--doc/--dir to analyze files)
  --txt PATH         Attach a text/CSV file's contents to the --ask prompt
  --doc PATH         Extract a document's text (PDF/DOCX/XLSX/PPTX/image via
                     liteparse) into the --ask prompt
  --dir PATH         Ingest all supported files in a directory (recursively) into
                     the LanceDB cache and answer from the most relevant chunks
  --pages RANGE      Limit --doc extraction to these pages, e.g. "1-5,10,15-20"
  --image PATH       Describe the given image using vision backend
  --audio PATH       Transcribe the given audio file using audio backend
  --top-k N          Chunks retrieved per query (default: 15)
  --chunk-size N     Characters per chunk when embedding (default: 1000)
  -h, --help         Show this help and exit
  -V, --version      Print version and exit

Subcommands / inspection:
  doctor                    Run the dependency check and exit
  cache [info|list|clear]   Inspect or clear the LanceDB vector cache
  --graph-stats             Show correlation-graph stats + top hubs
  --graph-query "<cypher>"  Run a raw Cypher query against the graph

Analyzing files with --txt/--doc/--dir also auto-updates a LadybugDB
correlation graph (entities per file; --dir uses Gemma for extraction). A bare
--ask automatically consults whatever you've indexed in the last 24h (LanceDB
chunks + graph correlations). Both caches live under ~/.gemma and expire after 24h.

Piped input: when no --txt/--doc/--dir is given, stdin is read as the document,
  e.g.  cat notes.txt | $(basename "$0") --ask "summarize this"
EOF
}

help_extra() {
    cat <<EOF

Large files (>${RAG_THRESHOLD_CHARS} chars) are automatically chunked, embedded
(model2vec) and stored in a LanceDB cache at:
  ${RAG_DB}
Only the chunks most relevant to your question are sent to the model.
Cached tables idle for >24h are evicted automatically on the next run.

Models (Gemma weights + embedder) are stored in the HuggingFace hub cache:
  ${HF_HOME}/hub
Env overrides: GEMMA_CACHE_DB, GEMMA_RAG_THRESHOLD, GEMMA_RAG_TOPK, GEMMA_CACHE_TTL, HF_HOME
EOF
}

check_deps() {
    local issues=0
    echo
    echo "Dependency check:"

    if command -v uvx >/dev/null 2>&1; then
        printf '  %-9s %s\n' "[ok]" "uvx (uv) — runs the model, liteparse, and RAG"
    else
        printf '  %-9s %s\n' "[MISSING]" "uvx (uv) — REQUIRED. Install: https://docs.astral.sh/uv/"
        issues=$((issues + 1))
    fi

    if [[ -f "$RAG_HELPER" ]]; then
        printf '  %-9s %s\n' "[ok]" "RAG helper ($RAG_HELPER)"
    else
        printf '  %-9s %s\n' "[MISSING]" "RAG helper not found at $RAG_HELPER — large-file retrieval disabled"
        issues=$((issues + 1))
    fi

    if command -v soffice >/dev/null 2>&1; then
        printf '  %-9s %s\n' "[ok]" "LibreOffice (soffice) — enables DOCX/XLSX/PPTX via --doc"
    else
        printf '  %-9s %s\n' "[warn]" "LibreOffice (soffice) not found — DOCX/XLSX/PPTX need it (PDF/images are fine)"
        printf '  %-9s %s\n' "" "install: brew install --cask libreoffice"
    fi

    printf '  %-9s %s\n' "[note]" "liteparse, litert-lm, lancedb, model2vec, ladybug auto-install via uvx on first use"

    local be
    if [[ -n "${GEMMA_BACKEND:-}" ]]; then be="$GEMMA_BACKEND (forced via GEMMA_BACKEND)"
    elif [[ -s "$BACKEND_CACHE" ]]; then be="$(cat "$BACKEND_CACHE") (auto-detected)"
    else be="not detected yet — run a query once"; fi
    printf '  %-9s %s\n' "[info]" "compute backend: $be"

    echo
    if [[ $issues -eq 0 ]]; then
        echo "All required dependencies present."
    else
        echo "Issues: $issues required dependency(ies) missing (see above)."
    fi
}

ensure_uvx() {
    command -v uvx >/dev/null 2>&1 && return 0
    echo "uv (uvx) not found — installing via https://astral.sh/uv ..." >&2
    curl -LsSf https://astral.sh/uv/install.sh | sh >&2 || {
        echo "Error: failed to install uv. See https://docs.astral.sh/uv/" >&2
        exit 1
    }
    export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
    command -v uvx >/dev/null 2>&1 || {
        echo "Error: uv installed but uvx not on PATH. Open a new shell and retry." >&2
        exit 1
    }
    echo "uv installed." >&2
}

cmd_cache() {
    local sub="${1:-info}"
    case "$sub" in
        ""|info|status)
            echo "Vector cache: $RAG_DB"
            if [[ -d "$RAG_DB" ]]; then
                local n
                n=$(find "$RAG_DB" -maxdepth 1 -name "*.lance" 2>/dev/null | wc -l | tr -d ' ')
                echo "Size:           $(du -sh "$RAG_DB" 2>/dev/null | cut -f1)"
                echo "Indexed tables: $n"
                echo "Eviction TTL:   ${RAG_TTL}s"
            else
                echo "(empty — nothing indexed yet)"
            fi
            ;;
        list)
            if [[ -d "$RAG_DB" ]]; then
                find "$RAG_DB" -maxdepth 1 -name "*.lance" 2>/dev/null \
                    | sed -E 's#.*/##; s#\.lance$##' | sort
            else
                echo "(empty)"
            fi
            ;;
        clear)
            rm -rf "$RAG_DB"
            echo "Cleared vector cache: $RAG_DB"
            ;;
        *)
            echo "Usage: $(basename "$0") cache [info|list|clear]" >&2
            return 1
            ;;
    esac
}

graph_model_path() {  # echo cached E4B model path (for --llm extraction), if present
    local repo="litert-community/gemma-4-E4B-it-litert-lm" file="gemma-4-E4B-it.litertlm"
    find "$HF_HOME/hub/models--${repo//\//--}/snapshots" -name "$file" 2>/dev/null | head -1
}

# Invoke the graph helper (update/stats/query). Best-effort for updates.
run_graph() {
    ensure_uvx
    uvx --python 3.12 --with ladybug python "$GRAPH_HELPER" \
        --db "$GRAPH_DB" --ttl "$RAG_TTL" "$@"
}

# Pick the compute backend: honor GEMMA_BACKEND, else use the cached choice,
# else probe the GPU once (fall back to CPU if it fails) and cache the result.
resolve_backend() {
    if [[ -n "${GEMMA_BACKEND:-}" ]]; then printf '%s' "$GEMMA_BACKEND"; return; fi
    if [[ -s "$BACKEND_CACHE" ]]; then cat "$BACKEND_CACHE"; return; fi
    local b="cpu"
    echo "Detecting compute backend (one-time)…" >&2
    if "${LITERT_RUN[@]}" --backend=gpu --max-num-tokens 64 --prompt "ok" >/dev/null 2>&1; then
        b="gpu"
    fi
    mkdir -p "$(dirname "$BACKEND_CACHE")"
    printf '%s' "$b" > "$BACKEND_CACHE"
    echo "Using $b backend (cached in $BACKEND_CACHE)." >&2
    printf '%s' "$b"
}

model_variant="e2b"
model_explicit=false
action=""
arg=""
txt_path=""
doc_path=""
dir_path=""
pages=""

# Subcommands / standalone flags (must be the first argument).
case "${1:-}" in
    -V|--version|version) echo "gemma $VERSION"; exit 0 ;;
    doctor)               echo "gemma $VERSION"; check_deps; exit 0 ;;
    cache)                shift; cmd_cache "$@"; exit $? ;;
    --graph-stats)        mkdir -p "$(dirname "$GRAPH_DB")"; run_graph --mode stats; exit $? ;;
    --graph-query)
        [[ -n "${2:-}" ]] || { echo "Usage: $(basename "$0") --graph-query \"<cypher>\"" >&2; exit 1; }
        run_graph --mode query --cypher "$2"; exit $?
        ;;
esac

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)
            [[ $# -ge 2 ]] || { echo "Error: --model requires a value" >&2; usage; exit 1; }
            case "$2" in
                e2b|e4b) model_variant="$2"; model_explicit=true ;;
                *) echo "Error: --model must be e2b or e4b" >&2; exit 1 ;;
            esac
            shift 2
            ;;
        --txt)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --txt requires a value" >&2; usage; exit 1; }
            [[ -f "$2" ]] || { echo "Error: text file not found: $2" >&2; exit 1; }
            txt_path="$2"
            shift 2
            ;;
        --doc)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --doc requires a value" >&2; usage; exit 1; }
            [[ -f "$2" ]] || { echo "Error: document not found: $2" >&2; exit 1; }
            doc_path="$2"
            shift 2
            ;;
        --dir)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --dir requires a value" >&2; usage; exit 1; }
            [[ -d "$2" ]] || { echo "Error: directory not found: $2" >&2; exit 1; }
            dir_path="$2"
            shift 2
            ;;
        --pages)
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: --pages requires a value" >&2; usage; exit 1; }
            pages="$2"
            shift 2
            ;;
        --top-k)
            [[ $# -ge 2 && "${2:-}" =~ ^[0-9]+$ ]] || { echo "Error: --top-k requires a number" >&2; exit 1; }
            RAG_TOPK="$2"
            shift 2
            ;;
        --chunk-size)
            [[ $# -ge 2 && "${2:-}" =~ ^[0-9]+$ ]] || { echo "Error: --chunk-size requires a number" >&2; exit 1; }
            CHUNK_SIZE="$2"
            shift 2
            ;;
        -V|--version)
            echo "gemma $VERSION"; exit 0
            ;;
        --ask|--image|--audio)
            [[ -z "$action" ]] || { echo "Error: only one of --ask/--image/--audio allowed" >&2; exit 1; }
            [[ $# -ge 2 && -n "${2:-}" ]] || { echo "Error: $1 requires a value" >&2; usage; exit 1; }
            action="$1"
            arg="$2"
            shift 2
            ;;
        -h|--help)
            usage
            help_extra
            check_deps
            exit 0
            ;;
        *)
            echo "Error: unknown argument: $1" >&2
            usage
            exit 1
            ;;
    esac
done

if [[ -z "$action" ]]; then
    usage
    exit 1
fi

inputs=0
[[ -n "$txt_path" ]] && inputs=$((inputs + 1))
[[ -n "$doc_path" ]] && inputs=$((inputs + 1))
[[ -n "$dir_path" ]] && inputs=$((inputs + 1))
if [[ $inputs -gt 1 ]]; then
    echo "Error: use only one of --txt, --doc or --dir" >&2
    exit 1
fi

if [[ $inputs -eq 1 && "$action" != "--ask" ]]; then
    echo "Error: --txt/--doc/--dir can only be used with --ask" >&2
    exit 1
fi

if [[ -n "$pages" && -z "$doc_path" ]]; then
    echo "Error: --pages requires --doc" >&2
    exit 1
fi

# Piped input: with --ask and no file/dir, read the document from stdin.
from_stdin=0
STDIN_TEXT=""
if [[ "$action" == "--ask" && $inputs -eq 0 && ! -t 0 ]]; then
    STDIN_TEXT="$(cat)"
    [[ -n "$STDIN_TEXT" ]] && from_stdin=1
fi

# File analysis (--txt/--doc/--dir/stdin) is a heavier task; default to the
# stronger e4b model unless the user explicitly picked one with --model.
if [[ ( $inputs -eq 1 || $from_stdin -eq 1 ) && "$model_explicit" == false ]]; then
    model_variant="e4b"
fi

# Models live in the HuggingFace hub cache (~/.cache/huggingface/hub). If the
# file is already cached we run it directly from that path — no network check,
# no "Downloading…" message. Only the first run (cache miss) pulls from HF.
case "$model_variant" in
    e2b) HF_REPO="litert-community/gemma-4-E2B-it-litert-lm"; MODEL_FILE="gemma-4-E2B-it.litertlm" ;;
    e4b) HF_REPO="litert-community/gemma-4-E4B-it-litert-lm"; MODEL_FILE="gemma-4-E4B-it.litertlm" ;;
esac
MODEL_SNAPS="$HF_HOME/hub/models--${HF_REPO//\//--}/snapshots"
MODEL_PATH="$(find "$MODEL_SNAPS" -name "$MODEL_FILE" 2>/dev/null | head -1)"
if [[ -n "$MODEL_PATH" && -e "$MODEL_PATH" ]]; then
    LITERT_RUN=(uvx litert-lm run "$MODEL_PATH")
else
    LITERT_RUN=(uvx litert-lm run --from-huggingface-repo "$HF_REPO" "$MODEL_FILE")
fi

ensure_uvx  # install uv on demand if it's missing
BACKEND="$(resolve_backend)"  # gpu, or cpu if the GPU backend isn't available

case "$action" in
    --ask)
        prompt="$arg"
        rag_extra=()
        [[ -n "$CHUNK_SIZE" ]] && rag_extra+=(--chunk-size "$CHUNK_SIZE")

        if [[ -n "$dir_path" ]]; then
            # Directory knowledge base: ingest (incrementally) and retrieve.
            mkdir -p "$(dirname "$RAG_DB")"
            echo "Indexing \"$dir_path\" into LanceDB (incremental)..." >&2
            context="$(uvx --python 3.12 --with lancedb --with model2vec \
                python "$RAG_HELPER" \
                --db "$RAG_DB" \
                --dir "$dir_path" \
                --recursive \
                --query "$arg" \
                --top-k "$RAG_TOPK" \
                --ttl "$RAG_TTL" \
                ${rag_extra[@]+"${rag_extra[@]}"})"
            prompt="$arg

Use the following excerpts from files in \"$dir_path\" to answer
(each excerpt is labeled with its source file):

$context"
            "${LITERT_RUN[@]}" --backend="$BACKEND" --prompt="$prompt"
            # Auto-update the correlation graph in the BACKGROUND (LLM extraction
            # for directories is slow on first build; detach so the answer is
            # not blocked). Progress is logged to GRAPH_LOG.
            mkdir -p "$(dirname "$GRAPH_DB")"
            graph_args=(--mode update --dir "$dir_path" --recursive)
            mp="$(graph_model_path)"; [[ -n "$mp" ]] && graph_args+=(--llm --model "$mp" --backend "$BACKEND")
            echo "Updating correlation graph in background (log: $GRAPH_LOG)" >&2
            ( run_graph "${graph_args[@]}" >>"$GRAPH_LOG" 2>&1 & )
            exit 0
        fi

        src=""
        extracted=""
        if [[ -n "$txt_path" ]]; then
            src="$txt_path"
            extracted="$(cat "$txt_path")"
        elif [[ -n "$doc_path" ]]; then
            src="$doc_path"
            parse_args=(--quiet "$doc_path")
            [[ -n "$pages" ]] && parse_args+=(--target-pages "$pages")
            extracted="$(uvx --from liteparse lit parse "${parse_args[@]}")"
        elif [[ $from_stdin -eq 1 ]]; then
            src="(stdin)"
            extracted="$STDIN_TEXT"
        fi

        if [[ -n "$src" ]]; then
            if [[ ${#extracted} -gt $RAG_THRESHOLD_CHARS ]]; then
                # Large input: retrieve only the relevant chunks via LanceDB.
                mkdir -p "$(dirname "$RAG_DB")"
                if [[ $from_stdin -eq 1 ]]; then
                    cache_key="stdin|$(printf '%s' "$extracted" | shasum | cut -d' ' -f1)|cs=${CHUNK_SIZE}"
                else
                    cache_key="$src|$(stat -f '%z-%m' "$src")|pages=${pages}|cs=${CHUNK_SIZE}"
                fi
                echo "Large input (${#extracted} chars) — retrieving relevant chunks via LanceDB..." >&2
                context="$(printf '%s' "$extracted" | uvx --python 3.12 --with lancedb --with model2vec \
                    python "$RAG_HELPER" \
                    --db "$RAG_DB" \
                    --cache-key "$cache_key" \
                    --query "$arg" \
                    --top-k "$RAG_TOPK" \
                    --ttl "$RAG_TTL" \
                    ${rag_extra[@]+"${rag_extra[@]}"})"
                prompt="$arg

Use the following excerpts from \"$(basename "$src")\" to answer:

$context"
            else
                prompt="$arg

Analyze the following document (\"$(basename "$src")\"):

$extracted"
            fi
        elif [[ $inputs -eq 0 && $from_stdin -eq 0 ]]; then
            # Bare --ask: automatically consult data ingested in the last 24h
            # (LanceDB chunks + LadybugDB entity correlations).
            kb_ctx=""
            if [[ -d "$RAG_DB" ]]; then
                kb_ctx="$(uvx --python 3.12 --with lancedb --with model2vec \
                    python "$RAG_HELPER" --db "$RAG_DB" --search-all \
                    --query "$arg" --top-k "$RAG_TOPK" --ttl "$RAG_TTL" 2>/dev/null || true)"
            fi
            graph_ctx=""
            if [[ -e "$GRAPH_DB" ]]; then
                graph_ctx="$(run_graph --mode correlate --query "$arg" 2>/dev/null || true)"
            fi
            if [[ -n "$kb_ctx" || -n "$graph_ctx" ]]; then
                prompt="$arg

The following may be relevant context from your previously indexed data:
${graph_ctx:+
$graph_ctx}
${kb_ctx:+
$kb_ctx}"
            fi
        fi

        "${LITERT_RUN[@]}" \
            --backend="$BACKEND" \
            --prompt="$prompt"

        # Auto-update the correlation graph for single files (heuristic, fast),
        # in the background so the answer isn't blocked.
        if [[ -n "$txt_path" || -n "$doc_path" ]]; then
            mkdir -p "$(dirname "$GRAPH_DB")"
            g_sig="$(stat -f '%z-%m' "$src" 2>/dev/null || echo 0)"
            ( printf '%s' "$extracted" | run_graph --mode update \
                --file-name "$src" --sig "$g_sig" >>"$GRAPH_LOG" 2>&1 & )
        fi
        ;;
    --image)
        "${LITERT_RUN[@]}" \
            --backend="$BACKEND" --vision-backend "$BACKEND" \
            --attachment "$arg" --prompt describe
        ;;
    --audio)
        "${LITERT_RUN[@]}" \
            --backend="$BACKEND" --audio-backend cpu \
            --attachment "$arg" --prompt transcribe
        ;;
esac
